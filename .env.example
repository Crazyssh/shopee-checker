# Port service
PORT=4100

# API key untuk auth (WAJIB set di production). Web utama kirim via header x-api-key.
API_KEY=ganti-dengan-random-string-panjang

# Halaman Shopee yang dipakai buat generate signature (default reset phone flow).
SHOPEE_URL=https://shopee.co.id/buyer/reset?scenario=7

# Headless mode (false = tampil browser, buat debug lokal).
HEADLESS=true

# Refresh halaman tiap N cek biar signature fresh.
MAX_CHECKS_BEFORE_REFRESH=40
